+        # (gemma3_causal.py line 646-649 passes input_embeds through correctly).
+        #
+        # Without this: _SGLangKeyRemap lets us use gemma3_mm (avoiding the
+        # flashinfer head_dim=256 JIT issue with gemma3_causal), but gemma3_mm
+        # doesn't wire input_embeds — so the whole NLA injection is a no-op.
+        if input_embeds is not None:
+            return self.language_model(input_ids, positions, forward_batch, input_embeds, **kwargs)

         # Replace image id with PAD if the image token if OOV, to avoid index-errors
