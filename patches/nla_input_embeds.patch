         bs = len(self.reqs)
@@ - self.input_embeds = torch.tensor(...).to(...)
-        self.input_embeds = (
-            torch.tensor(input_embeds).to(self.device, non_blocking=True)
-            if input_embeds
-            else None
-        )
+        # === NLA: from_numpy is zero-copy; concatenate is fast for ndarrays ===
+        # torch.tensor(nested_list) was ~83ms for 448K floats; this is ~0.1ms.
+        # Cast to bf16: transport is fp32 (numpy has no bf16), model weights are
+        # bf16, and Gemma's linear kernels strict-check dtype (Qwen's autocast).
+        import numpy as np
+        self.input_embeds = (
+            torch.from_numpy(
+                np.concatenate([np.asarray(e, dtype=np.float32) for e in input_embeds])
+            ).to(self.device, dtype=torch.bfloat16, non_blocking=True)
+            if input_embeds
+            else None
+        )
