+    def sync_weights():
+        actor_model.update_weights()
+        # Megatron: actor rank-0 placed the gathered embedding into the named
+        # ray actor; fetch it here (driver = sync ray client) and push to
+        # RolloutManager. nla_generate reads args._nla_embed_weight directly —
+        # zero NFS calls, no ray.get from inside the asyncio loop.
+        # FSDP writes the embed to a local file (single-node colocation).
+        if args.train_backend == "megatron":
+            ray.get(rollout_manager.set_embed.remote(ray.get(get_embed_store().get.remote())))
