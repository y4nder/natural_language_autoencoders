+    # === NLA patch: give RolloutManager a handle to the critic trainer ===
+    # nla.reward.nla_rm uses this to call critic_fwd on the idle critic GPUs
+    # during generation — live weights, no duplicate model, no checkpoint staleness.
+    if args.loss_type == "policy_loss":
+        assert args.use_critic, (
+            "NLA RL trains AV and AR simultaneously (the AR IS the reward "
